{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build Hotel System",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-I", "${workspaceFolder}/include",
                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/User.cpp",
                "${workspaceFolder}/src/Customer.cpp",
                "${workspaceFolder}/src/Admin.cpp",
                "${workspaceFolder}/src/Room.cpp",
                "${workspaceFolder}/src/Reservation.cpp",
                "${workspaceFolder}/src/Payment.cpp",
                "${workspaceFolder}/src/BookingHistory.cpp",
                "-o",
                "${workspaceFolder}/HotelReservationSystem.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Hotel Reservation System Build"
        }
    ]
}